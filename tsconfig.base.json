{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@etp/db": ["packages/db/src"],
      "@etp/contracts": ["packages/contracts/src"],
      "@etp/auth": ["packages/auth/src"],
      "@etp/sdk": ["packages/sdk/src"],
      "@etp/ui": ["packages/ui/src"],
      "@etp/utils": ["packages/utils/src"]
    }
  }
}
